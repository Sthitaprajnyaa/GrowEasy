# ── Server ────────────────────────────────────────────────
PORT=4000
# Comma-separated list of allowed frontend origins (CORS).
CORS_ORIGIN=http://localhost:3000

# ── Google Gemini ─────────────────────────────────────────
# Get a free API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Model to use for extraction. gemini-2.5-flash is fast + cheap and supports JSON mode.
GEMINI_MODEL=gemini-2.5-flash

# ── Extraction tuning ─────────────────────────────────────
# Number of CSV rows sent to the LLM per request.
BATCH_SIZE=15
# How many batches to process in parallel.
BATCH_CONCURRENCY=3
# Retry attempts per batch on transient failure.
MAX_RETRIES=3
# Max upload size in megabytes.
MAX_FILE_SIZE_MB=10
